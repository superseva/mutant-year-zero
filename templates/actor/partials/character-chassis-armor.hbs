<div class="box-item physical header flex row align-center space-between {{system.creatureType}}">
    <label class="item-name">{{localize "MYZ.CHASSIS"}}</label>
    <div class="item-values grid center">
        <label>{{localize 'MYZ.ARMOR'}}</label>
        <span>{{localize 'MYZ.STATS'}}</span>
    </div>
    <div class="item-controls">
         <a class="item-create" data-action="createDoc" data-type="chassis">{{localize "MYZ.Add"}}</a>
    </div>
</div>
<ol class="box-list {{system.creatureType}}">
    {{#each chassis as |item key|}}
    <li class="box-item physical flex row align-center space-between editable-armor item-edit" data-physical="1" data-item-id="{{item._id}}">
        <span class="item-name flex row align-center {{#if (isBroken item)}}broken{{/if}}" data-item-id="{{item._id}}">
            <img class="item-image" src="{{item.img}}" />
            <label class="">{{item.name}}</label>
        </span>
        <div class="item-values grid center">
            <label>{{item.system.armor}}</label>
            <label style="font-size:12px"><strong>{{item.system.strength}}&nbsp;-&nbsp;{{item.system.agility}}&nbsp;-&nbsp; {{item.system.wits}}&nbsp;-&nbsp;{{item.system.empathy}}</strong></label>
        </div>
        <div class="item-controls">
            {{> systems/mutant-year-zero/templates/actor/partials/item-edit-controls.hbs item=item}}
            {{!-- {{#unless item.system.stashed}}
            <a class="item-control item-toggle {{#unless item.system.equipped}}item-unequipped{{/unless}}" data-action="toggleValue" data-linked-value="equipped" data-item-id="{{item._id}}" title='{{localize "MYZ.EQUIPPED"}}'>
                <i class="fas fa-tshirt"></i>
            </a>{{/unless}}
            {{#if item.system.stashed}}<a class="item-control item-stash-toggle" data-action="toggleValue" data-linked-value="stashed" data-item-id="{{item._id}}" title='{{localize "MYZ.UN_STASH_ITEM"}}'>
                <i class="fa-regular fa-box"></i>
            </a>{{/if}} --}}
        </div>
    </li>
    {{/each}}
</ol>