<div class="box-item physical header flex row align-center space-between weapon {{system.creatureType}}">
    <label class="item-name">{{localize "MYZ.WEAPONS"}}</label>
    <div class="item-values grid grid-3col center">
        <label>{{localize 'MYZ.BONUS'}}</label>
        <label>{{localize 'MYZ.DAMAGE'}}</label>
        <label>{{localize 'MYZ.RANGE'}}</label>
    </div>
    <div class="item-controls">
        <a class="item-create" data-action="createDoc" data-type="weapon">{{localize "MYZ.Add"}}</a>
    </div>
</div>
<ol class="box-list {{system.creatureType}}">
    {{#each weapons as |item key|}}
    <li class="box-item physical flex row align-center space-between editable-item weapon item-edit" data-physical="1" data-item-id="{{item._id}}">
        <span class="item-name flex row align-center roll-weapon rollable {{#if (isBroken item)}}broken{{/if}}" data-item-id="{{item._id}}">
            <img class="item-image" src="{{item.img}}" />
            <a data-action="onRollWeapon" data-item-id="{{item._id}}">{{item.name}}</a>
            {{#if (isArtifact item)}} <img class="item-image" src="systems/mutant-year-zero/assets/ico/trophy.svg" style="border:none" />{{/if}}
        </span>
        <div class="item-values grid grid-3col align-center center">
            <span>
                <input type="number" class="owned-item-value num-value-1rem myz-gear-dice" name="items.{{item._id}}.system.bonus.value" value="{{item.system.bonus.value}}" data-linked-value="system.bonus.value" data-item-id="{{item._id}}">
                <label>/{{item.system.bonus.max}}</label>
            </span>
            <!-- <label class="flex flex-center">{{item.system.bonus.value}} / {{item.system.bonus.max}}</label> -->
            <label class="flex flex-center">{{item.system.damage}}</label>
            <label class="flex flex-center">{{localize (toUpperCase (concat "MYZ." item.system.range))}}</label>
        </div>

        {{> systems/mutant-year-zero/templates/actor/partials/item-edit-controls.hbs item=item}}
    </li>
    {{/each}}
</ol>