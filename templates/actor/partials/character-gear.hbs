<div class="box-item header flex row align-center space-between {{system.creatureType}}">
    <label class="item-name">{{localize "MYZ.GEAR"}}</label>
    <span class="item-controls">
        <a class="item-create" data-action="createDoc" data-type="gear">{{localize "MYZ.Add"}}</a>
    </span>
</div>
<ol class="box-list gear {{system.creatureType}}">
    {{#each gear as |item key|}}
    <li class="box-item gear flex row align-center space-between editable-item  item-edit" data-physical="1" data-item-id="{{item._id}}">
        <div class="item-name flex row align-center">
            <img class="item-image" src="{{item.img}}" />
            <a data-action="viewDoc" data-item-id="{{item._id}}">{{item.name}} &nbsp;</a>
            <label>&nbsp;x</label>
            <input type="number" class="owned-item-value num-value-1rem" name="items.{{item._id}}.system.quantity" value="{{item.system.quantity}}" data-item-id="{{item._id}}" data-linked-value="system.quantity">
            
        </div>
        <div><label style="padding-left: 10px;"><i class="fas fa-weight-hanging"></i>:{{math item.system.quantity "*" item.system.weight}}</label></div>
        {{!-- <span class="item-controls">
            <label><i class="fas fa-weight-hanging"></i>:{{math item.system.quantity "*" item.system.weight}}</label>
            <!-- <label><i class="fas fa-weight-hanging"></i>:{{item.system.weight}}</label> -->
            {{#if item.system.stashed}}<a class="item-control item-stash-toggle" title='{{localize "MYZ.UN_STASH_ITEM"}}'>
                <i class="fa-regular fa-box"></i>
            </a>{{/if}}
        </span> --}}

        {{> systems/mutant-year-zero/templates/actor/partials/item-edit-controls.hbs item=item}}
    </li>
    {{/each}}
</ol>